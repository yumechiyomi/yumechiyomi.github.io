---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Glass Chat</title>

<style>

*{
    box-sizing:border-box;
}

html,
body{
    margin:0;
    width:100%;
    height:100%;
    overflow:hidden;

    font-family:Arial,sans-serif;

    background:transparent !important;

    color:white;
}

body{

    background:
        linear-gradient(
            135deg,
            rgba(15,23,42,0.25),
            rgba(30,41,59,0.15)
        ) !important;

    backdrop-filter:blur(10px);

    -webkit-backdrop-filter:blur(10px);
}

/* LOGIN MENU */

#authMenu{

    position:fixed;

    inset:0;

    display:flex;

    justify-content:center;

    align-items:center;

    background:
        rgba(0,0,0,0.08);

    backdrop-filter:
        blur(15px);

    -webkit-backdrop-filter:
        blur(15px);

    z-index:1000;
}

.authBox{

    width:350px;

    padding:25px;

    border-radius:24px;

    background:
        rgba(255,255,255,0.03);

    border:
        1px solid rgba(
            255,
            255,
            255,
            0.08
        );

    backdrop-filter:
        blur(30px);

    -webkit-backdrop-filter:
        blur(30px);

    box-shadow:
        0 0 40px rgba(
            0,
            0,
            0,
            0.15
        );
}

.authTabs{

    display:flex;

    gap:10px;

    margin-bottom:15px;
}

.authTabs button{
    flex:1;
}

/* INPUT */

input{

    width:100%;

    padding:12px;

    margin-top:10px;

    border:none;

    outline:none;

    border-radius:14px;

    background:
        rgba(255,255,255,0.03);

    border:
        1px solid rgba(
            255,
            255,
            255,
            0.05
        );

    color:white;

    backdrop-filter:
        blur(10px);

    -webkit-backdrop-filter:
        blur(10px);
}

input::placeholder{
    color:#d1d5db;
}

/* BUTTON */

button{

    border:none;

    cursor:pointer;

    padding:12px;

    border-radius:14px;

    background:
        rgba(88,101,242,0.65);

    color:white;

    margin-top:10px;

    transition:0.2s;

    backdrop-filter:
        blur(10px);

    -webkit-backdrop-filter:
        blur(10px);
}

button:hover{

    transform:scale(1.03);

    background:
        rgba(88,101,242,0.85);
}

/* CHAT */

#app{

    height:100vh;

    display:flex;

    flex-direction:column;
}

#topbar{

    padding:15px 20px;

    background:
        rgba(255,255,255,0.02);

    backdrop-filter:
        blur(25px);

    -webkit-backdrop-filter:
        blur(25px);

    display:flex;

    justify-content:space-between;

    align-items:center;

    border-bottom:
        1px solid rgba(
            255,
            255,
            255,
            0.05
        );
}

#chat{

    flex:1;

    overflow-y:auto;

    padding:20px;
}

/* SCROLLBAR */

#chat::-webkit-scrollbar{
    width:8px;
}

#chat::-webkit-scrollbar-thumb{

    background:
        rgba(255,255,255,0.08);

    border-radius:20px;
}

/* MESSAGE */

.message{

    background:
        rgba(255,255,255,0.03);

    border:
        1px solid rgba(
            255,
            255,
            255,
            0.05
        );

    padding:14px;

    border-radius:18px;

    margin-bottom:14px;

    backdrop-filter:
        blur(20px);

    -webkit-backdrop-filter:
        blur(20px);

    animation:
        fadeIn .25s ease;
}

.username{

    color:#7aa2ff;

    font-weight:bold;

    margin-bottom:5px;
}

.time{

    color:#bdbdbd;

    font-size:12px;

    margin-top:6px;
}

/* BOTTOM BAR */

#bottomBar{

    padding:15px;

    display:flex;

    gap:10px;

    background:
        rgba(255,255,255,0.02);

    backdrop-filter:
        blur(25px);

    -webkit-backdrop-filter:
        blur(25px);

    border-top:
        1px solid rgba(
            255,
            255,
            255,
            0.05
        );
}

#messageInput{
    flex:1;
}

/* UTIL */

.hidden{
    display:none;
}

/* ANIMATION */

@keyframes fadeIn{

    from{
        opacity:0;
        transform:translateY(10px);
    }

    to{
        opacity:1;
        transform:translateY(0);
    }
}
</style>
</head>
<body>

<!-- AUTH -->

<div id="authMenu">

    <div class="authBox">

        <div class="authTabs">

            <button onclick="showLogin()">
                Login
            </button>

            <button onclick="showRegister()">
                Register
            </button>

        </div>

        <!-- LOGIN -->

        <div id="loginPanel">

            <input
                id="loginUser"
                placeholder="Username"
            >

            <input
                id="loginPass"
                type="password"
                placeholder="Password"
            >

            <button onclick="login()">
                Login
            </button>

        </div>

        <!-- REGISTER -->

        <div
            id="registerPanel"
            class="hidden"
        >

            <input
                id="registerUser"
                placeholder="Username"
            >

            <input
                id="registerPass"
                type="password"
                placeholder="Password"
            >

            <button onclick="register()">
                Create Account
            </button>

        </div>

    </div>

</div>

<!-- APP -->

<div id="app">

    <div id="topbar">

        <div id="status">
            Not logged in
        </div>

        <button onclick="logout()">
            Logout
        </button>

    </div>

    <div id="chat"></div>

    <div id="bottomBar">

        <input
            id="messageInput"
            placeholder="Type message..."
        >

        <button onclick="sendMessage()">
            Send
        </button>

    </div>

</div>

<script>

class ServerStorage{

    constructor(options={}){

        this.serverUrl =
            options.serverUrl ||
            'https://ikelene.dev/storage/';

        this.apiKey =
            options.apiKey ||
            '';
    }

    async api(
        endpoint,
        body={}
    ){

        const response =
            await fetch(
                this.serverUrl + endpoint,
                {
                    method:'POST',

                    headers:{
                        'Content-Type':
                            'application/json'
                    },

                    body:
                        JSON.stringify(body)
                }
            );

        return await response.json();
    }

    async save(key,value){

        return await this.api(
            'store.php',
            {
                apiKey:
                    this.apiKey,

                key,

                value,

                mimeType:
                    'text/plain'
            }
        );
    }

    async get(key){

        const result =
            await this.api(
                'get.php',
                {
                    apiKey:
                        this.apiKey,

                    key
                }
            );

        if(
            result.success &&
            result.data
        ){
            return result.data.value;
        }

        return null;
    }

    async exists(key){

        const result =
            await this.api(
                'get.php',
                {
                    apiKey:
                        this.apiKey,

                    key
                }
            );

        return (
            result.success &&
            !!result.data
        );
    }
}

/* API */

const storage =
    new ServerStorage({

        apiKey:
        '426d726545902a464211ee51efda5956158f5696'

    });

/* ELEMENTS */

const authMenu =
    document.getElementById(
        'authMenu'
    );

const loginPanel =
    document.getElementById(
        'loginPanel'
    );

const registerPanel =
    document.getElementById(
        'registerPanel'
    );

const chatBox =
    document.getElementById(
        'chat'
    );

const statusText =
    document.getElementById(
        'status'
    );

let currentUser = null;

/* UI */

function showLogin(){

    loginPanel.classList
        .remove('hidden');

    registerPanel.classList
        .add('hidden');
}

function showRegister(){

    registerPanel.classList
        .remove('hidden');

    loginPanel.classList
        .add('hidden');
}

function setStatus(text){

    statusText.textContent =
        text;
}

/* ACCOUNT */

async function register(){

    const username =
        document.getElementById(
            'registerUser'
        ).value.trim();

    const password =
        document.getElementById(
            'registerPass'
        ).value.trim();

    if(
        !username ||
        !password
    ){
        alert('Missing info');
        return;
    }

    const exists =
        await storage.exists(
            'user_' + username
        );

    if(exists){

        alert(
            'Username already exists'
        );

        return;
    }

    await storage.save(
        'user_' + username,

        JSON.stringify({

            password,

            created:
                Date.now()

        })
    );

    alert(
        'Account created'
    );

    showLogin();
}

async function login(){

    const username =
        document.getElementById(
            'loginUser'
        ).value.trim();

    const password =
        document.getElementById(
            'loginPass'
        ).value.trim();

    const data =
        await storage.get(
            'user_' + username
        );

    if(!data){

        alert(
            'User not found'
        );

        return;
    }

    const user =
        JSON.parse(data);

    if(
        user.password !== password
    ){

        alert(
            'Wrong password'
        );

        return;
    }

    currentUser =
        username;

    localStorage.setItem(
        'savedUser',
        username
    );

    authMenu.style.display =
        'none';

    setStatus(
        'Logged in as ' +
        username
    );

    loadMessages();
}

function logout(){

    currentUser = null;

    localStorage.removeItem(
        'savedUser'
    );

    authMenu.style.display =
        'flex';

    setStatus(
        'Not logged in'
    );

    chatBox.innerHTML = '';
}

/* CHAT */

async function loadMessages(){

    if(!currentUser){
        return;
    }

    const data =
        await storage.get(
            'chat_global'
        );

    let messages = [];

    if(data){

        try{

            messages =
                JSON.parse(data);

        }catch{}
    }

    chatBox.innerHTML = '';

    for(
        const msg
        of messages
    ){

        const div =
            document.createElement(
                'div'
            );

        div.className =
            'message';

        const date =
            new Date(
                msg.time
            );

        div.innerHTML = `
            <div class="username">
                ${escapeHtml(msg.user)}
            </div>

            <div>
                ${escapeHtml(msg.message)}
            </div>

            <div class="time">
                ${date.toLocaleTimeString()}
            </div>
        `;

        chatBox.appendChild(div);
    }

    chatBox.scrollTop =
        chatBox.scrollHeight;
}

async function sendMessage(){

    if(!currentUser){

        alert(
            'Login first'
        );

        return;
    }

    const input =
        document.getElementById(
            'messageInput'
        );

    const text =
        input.value.trim();

    if(!text){
        return;
    }

    const data =
        await storage.get(
            'chat_global'
        );

    let messages = [];

    if(data){

        try{

            messages =
                JSON.parse(data);

        }catch{}
    }

    messages.push({

        user:
            currentUser,

        message:
            text,

        time:
            Date.now()

    });

    if(
        messages.length > 100
    ){

        messages =
            messages.slice(-100);
    }

    await storage.save(
        'chat_global',

        JSON.stringify(messages)
    );

    input.value = '';

    loadMessages();
}

function escapeHtml(text){

    const div =
        document.createElement(
            'div'
        );

    div.textContent = text;

    return div.innerHTML;
}

/* AUTO LOGIN */

const savedUser =
    localStorage.getItem(
        'savedUser'
    );

if(savedUser){

    currentUser =
        savedUser;

    authMenu.style.display =
        'none';

    setStatus(
        'Logged in as ' +
        savedUser
    );

    loadMessages();
}

/* REALTIME */

setInterval(
    loadMessages,
    2000
);

</script>

</body>
</html>
